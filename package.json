{
  "name": "synexus",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "android:icons": "node scripts/generate-android-icons.mjs",
    "android:bundle": "npm run build && npx cap sync android && node scripts/android-release.mjs bundle",
