# Copy to android/keystore.properties (never commit the real file).
# Generate upload keystore once (keep backups offline):
#
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias synexus-upload
#
# Paths below are relative to the android/ project root.

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=synexus-upload
storeFile=upload-keystore.jks
