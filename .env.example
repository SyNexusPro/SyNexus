# Browser bundle (must exist when Vercel runs `vite build` — add under Project → Settings → Environment Variables)
# Android/iOS: same VITE_* vars are embedded at `npm run build` — keep .env locally before `npm run android:bundle`.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side alias (webhooks, analytics API) — same project URL
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

VITE_BIRDEYE_API_KEY=your-birdeye-api-key
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
VITE_APP_URL=http://localhost:5173

# Subscription billing — set SUBSCRIPTION_PROVIDER=stripe|creem|none (auto-detects from keys if unset)
SUBSCRIPTION_PROVIDER=stripe

# Stripe (when SUBSCRIPTION_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRICE_ID_PRO=price_replace_pro
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional legacy Creem (when SUBSCRIPTION_PROVIDER=creem)
# CREEM_API_KEY=creem_test_replace_me
# CREEM_PRODUCT_ID_PRO=prod_replace_pro
# CREEM_WEBHOOK_SECRET=whsec_replace_me

# Optional external pricing page URL for /pricing
# VITE_SUBSCRIPTION_PRICING_URL=

# Optional alias — vite.config.ts falls back if VITE_SUPABASE_ANON_KEY is missing
SUPABASE_ANON_KEY=your-anon-key

# Owner command code — server-only (never VITE_*). Unlocks full Pro without payment.
# Set your own values; run: node scripts/generate-owner-code.mjs
SYNEXUS_OWNER_EMAIL=owner@synexus.pro
SYNEXUS_OWNER_PASSWORD=change-me-to-a-long-secret
SYNEXUS_OWNER_SIGNING_KEY=optional-separate-signing-key

# Titan AI — server-only (never VITE_*). Powers real conversations in /api/titan/chat
OPENAI_API_KEY=sk_replace_me
# Or use TITAN_API_KEY / TITAN_API_BASE for OpenRouter, Groq, etc.
# TITAN_API_KEY=
# TITAN_API_BASE=https://api.openai.com/v1
# TITAN_MODEL=gpt-4o-mini
# TITAN_MODEL_PRO=gpt-4o
# TITAN_MODEL_FREE=gpt-4o-mini
# TITAN_MAX_TOKENS=800
# TITAN_MAX_TOKENS_PRO=1100

# Optional — affiliate payout dashboard (Hub). When set, the payout control opens this URL in a new tab.
# VITE_AFFILIATE_PAYOUT_URL=https://your-payout-or-connect-portal.example

# Optional — SYN community token (defaults to known mint if unset)
# VITE_SYN_MINT=9naVtLAGKWYuEcGehe1BZ3DpiSLHjSNsaeFr2JPHpump
# VITE_SYN_PUMPFUN_URL=https://pump.fun/communities/9naVtLAGKWYuEcGehe1BZ3DpiSLHjSNsaeFr2JPHpump
# VITE_SYN_LIVE=1
