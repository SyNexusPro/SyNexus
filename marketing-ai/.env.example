# Public app URL in all social posts
APP_ORIGIN=https://your-live-app-url.com

# ─── YouTube (daily Shorts) ───
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost
YOUTUBE_REFRESH_TOKEN=
# YOUTUBE_PRIVACY=public

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Discord ───
DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=          # run: npm run discord:channels
# DISCORD_GUILD_ID=
# DISCORD_MARKETING_CHANNEL=marketing

# ─── Reddit ───
# Create app: https://www.reddit.com/prefs/apps (script or web)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:8080
REDDIT_REFRESH_TOKEN=
REDDIT_SUBREDDIT=YourSubredditName
# REDDIT_USER_AGENT=SynexusDailyBot/1.0 by your_reddit_username

# ─── TikTok (Content Posting API — auto-post 2–3× daily) ───
# 1. developers.tiktok.com → app → Login Kit + Content Posting API + Direct Post
# 2. Request video.publish scope
# 3. Redirect URI must be https (use ngrok for local auth)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-domain.com/callback
TIKTOK_REFRESH_TOKEN=
# TIKTOK_ACCESS_TOKEN=         # auto-refreshed
# TIKTOK_OPEN_ID=
# TIKTOK_PRIVACY=PUBLIC_TO_EVERYONE
TIKTOK_POSTS_PER_DAY=3
TIKTOK_POST_HOURS=9,14,20

# ─── Meta (Facebook Page + Instagram Reels) ───
# developers.facebook.com → Business app → Facebook Login + Instagram Graph API
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://localhost/
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=

# ─── X / Twitter ───
# App keys from developer.x.com → Keys and tokens
# X_API_KEY=              Consumer key (API key)
# X_API_SECRET=           Consumer secret (API secret)
# X_BEARER_TOKEN=         App-only bearer (read/search — not for posting)
# X_ACCESS_TOKEN=         User access token (npm run x:auth or portal Generate)
# X_ACCESS_SECRET=        User access secret

# ─── 3× daily blast (all platforms) ───
POSTS_PER_DAY=3
POST_HOURS=9,14,20

# ─── 7-day viral launch ───
# LAUNCH_START_DATE=2026-06-20
# TELEGRAM_CHANNEL_URL=https://t.me/your_synexus_channel

# ─── Video ───
# VIDEO_OUTPUT_DIR=
# Natural female voice (Microsoft Neural). Alternatives: en-US-JennyNeural, en-US-AvaNeural
VIDEO_TTS_VOICE=en-US-AriaNeural
