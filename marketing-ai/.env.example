# Public app URL in all social posts
APP_ORIGIN=https://your-live-app-url.com

# ─── YouTube (daily Shorts) ───
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost
YOUTUBE_REFRESH_TOKEN=
# YOUTUBE_PRIVACY=public

# ─── Telegram ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Discord ───
DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=          # run: npm run discord:channels
# DISCORD_GUILD_ID=
# DISCORD_MARKETING_CHANNEL=marketing

# ─── Reddit ───
# Create app: https://www.reddit.com/prefs/apps (script or web)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:8080
REDDIT_REFRESH_TOKEN=
REDDIT_SUBREDDIT=YourSubredditName
# REDDIT_USER_AGENT=SynexusDailyBot/1.0 by your_reddit_username

# ─── TikTok (Content Posting API — auto-post 2–3× daily) ───
# 1. developers.tiktok.com → app → Login Kit + Content Posting API + Direct Post
# 2. Request video.publish scope
# 3. Redirect URI must be https (use ngrok for local auth)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://your-domain.com/callback
TIKTOK_REFRESH_TOKEN=
# TIKTOK_ACCESS_TOKEN=         # auto-refreshed
# TIKTOK_OPEN_ID=
# TIKTOK_PRIVACY=PUBLIC_TO_EVERYONE
TIKTOK_POSTS_PER_DAY=3
TIKTOK_POST_HOURS=9,14,20

# ─── Video ───
# VIDEO_OUTPUT_DIR=
# VIDEO_TTS_VOICE=en-US-GuyNeural
